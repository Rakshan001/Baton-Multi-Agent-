{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "baton-daemon",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dist/cli.js", "serve", "--write", "-p", "7077"],
      "port": 7077
    },
    {
      "name": "baton-web",
      "runtimeExecutable": "/Applications/Cursor.app/Contents/Resources/app/resources/helpers/node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5173", "--strictPort"],
      "cwd": "web",
      "port": 5173
    },
    {
      "name": "baton-site",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "site",
      "port": 3000
    }
  ]
}
